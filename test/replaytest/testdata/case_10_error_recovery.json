{
  "name": "error_recovery",
  "description": "异常恢复：模拟重复写入和验证去重，检查是否出现重复 event 或状态污染",
  "app_name": "replay-matrix",
  "user_id": "user-error-recovery",
  "session_id": "session-error-recovery",
  "steps": [
    {
      "type": "create_session",
      "state": {"initial": true}
    },
    {
      "type": "append_event",
      "event": {
        "author": "user", "role": "user",
        "content": "first message",
        "branch": "root", "filter_key": "root"
      }
    },
    {
      "type": "append_event",
      "event": {
        "author": "agent", "role": "assistant",
        "content": "first response",
        "branch": "root", "filter_key": "root"
      }
    },
    {
      "type": "append_event",
      "event": {
        "author": "user", "role": "user",
        "content": "first message",
        "branch": "root", "filter_key": "root"
      }
    },
    {
      "type": "append_event",
      "event": {
        "author": "agent", "role": "assistant",
        "content": "first response",
        "branch": "root", "filter_key": "root"
      }
    },
    {"type": "get_session"}
  ],
  "verify": {
    "events_count": 4
  }
}
