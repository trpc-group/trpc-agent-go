{
  "name": "single_turn",
  "description": "单轮普通对话：一个 user message 和一个 assistant text event",
  "app_name": "replay-matrix",
  "user_id": "user-single-turn",
  "session_id": "session-single-turn",
  "steps": [
    {
      "type": "create_session",
      "state": {
        "seed": {"case": "single_turn"}
      }
    },
    {
      "type": "append_event",
      "event": {
        "author": "user",
        "role": "user",
        "content": "hello replay",
        "branch": "root",
        "filter_key": "root",
        "state_delta": {
          "turn": {"index": 1}
        }
      }
    },
    {
      "type": "append_event",
      "event": {
        "author": "agent",
        "role": "assistant",
        "content": "hello from agent",
        "branch": "root",
        "filter_key": "root"
      }
    },
    {
      "type": "get_session"
    }
  ],
  "verify": {
    "events_count": 2
  }
}
