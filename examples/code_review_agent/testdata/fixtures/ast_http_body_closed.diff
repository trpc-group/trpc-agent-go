diff --git a/http_client_safe.go b/http_client_safe.go
new file mode 100644
--- /dev/null
+++ b/http_client_safe.go
@@ -0,0 +1,17 @@
+package example
+
+import (
+	"net/http"
+	"io"
+)
+
+func fetchURLSafe(url string) (string, error) {
+	resp, err := http.Get(url)
+	if err != nil {
+		return "", err
+	}
+	defer resp.Body.Close()
+	body, rerr := io.ReadAll(resp.Body)
+	if rerr != nil {
+		return "", rerr
+	}
+	return string(body), nil
+}
