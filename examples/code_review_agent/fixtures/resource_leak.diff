+func ReadMultipleFiles(paths []string) ([]string, error) {
+    var results []string
+    for _, path := range paths {
+        f, err := os.Open(path)
+        if err != nil {
+            return results, err
+        }
+        defer f.Close()
+        content, _ := os.ReadFile(path)
+        results = append(results, string(content))
