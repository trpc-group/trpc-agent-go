+package utils
+
+import "fmt"
+
+func Add(a, b int) int {
+    return a + b
+}
+
+func Multiply(a, b int) int {
+    return a * b
+}
+
+func FormatResult(result int) string {
+    return fmt.Sprintf("Result: %d", result)
+}
+
+func ProcessNumbers(numbers []int) int {
+    sum := 0
+    for _, n := range numbers {
+        sum += n
+    }
+    return sum
+}