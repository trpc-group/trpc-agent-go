+func Login(db *sql.DB, username string) (*User, error) {
+	query := "SELECT id, name FROM users WHERE name = '" + username + "'"
+	rows, err := db.Query(query)
+	if err != nil {
+		return nil, err
+	}
+	var u User
+	if rows.Next() {
+		rows.Scan(&u.ID, &u.Name)
+	}
+	return &u, nil
+}
