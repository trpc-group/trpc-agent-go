 func (s *OrderStore) CreateOrder(ctx context.Context, order Order) error {
+	tx, err := s.db.Begin()
+	if err != nil {
+		return err
+	}
+	_, err = tx.ExecContext(ctx, "INSERT INTO orders(id) VALUES (?)", order.ID)
+	return err
 }
 
